rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email in [
        'hhluan@hcmus.edu.vn',
        'nthue@hcmus.edu.vn'
      ];
    }

    function isAcceptedMember(classId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/classes/$(classId)/members/$(request.auth.token.email))
        && firestore.get(/databases/(default)/documents/classes/$(classId)/members/$(request.auth.token.email)).data.status == 'accepted';
    }

    match /classes/{classId}/materials/{fileName=**} {
      allow read: if isAdmin() || isAcceptedMember(classId);
      allow write: if isAdmin();
    }

    match /classes/{classId}/announcements/{fileName=**} {
      allow read: if isAdmin() || isAcceptedMember(classId);
      allow write: if isAdmin() || isAcceptedMember(classId);
    }

    match /classes/{classId}/submissions/{assignmentId}/{email}/{fileName=**} {
      allow read: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow write: if isAcceptedMember(classId) && request.auth.token.email == email;
    }
  }
}
