rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email in [
        'hhluan@hcmus.edu.vn',
        'nthue@hcmus.edu.vn'
      ];
    }

    function memberDoc(classId, email) {
      return /databases/$(database)/documents/classes/$(classId)/members/$(email);
    }

    function hasMembership(classId) {
      return signedIn() && exists(memberDoc(classId, request.auth.token.email));
    }

    function isAcceptedMember(classId) {
      return hasMembership(classId)
        && get(memberDoc(classId, request.auth.token.email)).data.status == 'accepted';
    }

    match /classCodes/{code} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /classSummaries/{classId} {
      allow get: if isAdmin() || hasMembership(classId);
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow get: if isAdmin() || isAcceptedMember(classId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();

      match /members/{email} {
        allow read: if isAdmin()
          || isAcceptedMember(classId)
          || (signedIn() && request.auth.token.email == email)
          || (signedIn() && resource.data.email == request.auth.token.email);

        allow create: if isAdmin()
          || (
            signedIn()
            && request.auth.token.email == email
            && request.resource.data.email == request.auth.token.email
            && request.resource.data.status == 'pending'
          );

        allow update, delete: if isAdmin();
      }
    }
  }
}
